generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  INBOUND_ADMIN
  PICKER_ADMIN
  PACKER_ADMIN
  PICKER
  PACKER
  SALES_AGENT
  STOCK_KEEPER
  WAREHOUSE_ADMIN
}

enum StockStatus {
  PENDING
  IN_STOCK
  OUT_OF_STOCK
}

enum StockUnit {
  KG
  PCS
}

enum MovementType {
  IN
  USED
  TRANSFER
  ADJUSTMENT_OUT
}

enum SalesPlatform {
  FACEBOOK
  TIKTOK
  INSTAGRAM
  SHOPEE_VIDEO
}

enum ContentPostType {
  POST
  VIDEO
  REEL
}

enum SaleChannel {
  FACEBOOK
  TIKTOK
  INSTAGRAM
  MARKETPLACE
  OTHERS
}

enum OrderStatus {
  INBOUND
  PICKER_ASSIGNED
  PICKING
  PICKER_COMPLETE
  PACKER_ASSIGNED
  PACKING
  PACKER_COMPLETE
  OUTBOUND
}

enum Platform {
  SHOPEE
  LAZADA
  TIKTOK
  DIRECT
  OTHER
}

enum IncidentType {
  WRONG_ITEM_PICKED
  WRONG_ITEM_PACKED
  MISSING_ITEM
  WRONG_QUANTITY
  PARCEL_DAMAGE
  LOST_PARCEL
  UNSCANNED_PARCEL
  LATE_PROCESSING
  INVENTORY_DISCREPANCY
  DAMAGED_INVENTORY
  LOW_PRODUCTIVITY
  FAILURE_TO_FOLLOW_SOP
  UNAUTHORIZED_ABSENCE
  MISCONDUCT
  COMPANY_PROPERTY_DAMAGE
  SAFETY_INCIDENT
  UNDERTIME
  FAILURE_TO_SUBMIT_REPORTS
  FAILURE_POSTING_SCHEDULE
  POOR_QUALITY_CONTENT
  UNAUTHORIZED_RECORDING
  WRONG_SALES_ENCODING
  COURIER_COORDINATION_FAILURE
  FAILURE_TURN_OVER_PARCELS
  MISMATCH_PARCEL_COUNT
}

// ─── Tables ───────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  users  User[]
  orders Order[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  username     String
  passwordHash String   @map("password_hash")
  email        String?  @map("email")
  role         UserRole
  isActive     Boolean  @default(true) @map("is_active")
  createdById  String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant       Tenant @relation(fields: [tenantId], references: [id])
  createdBy    User?  @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers User[] @relation("UserCreatedBy")

  scannedOrders        Order[]              @relation("ScannedBy")
  pickerAssignments    PickerAssignment[]   @relation("PickerUser")
  pickerAssignedByMe   PickerAssignment[]   @relation("PickerAssignedBy")
  packerAssignments    PackerAssignment[]   @relation("PackerUser")
  packerAssignedByMe   PackerAssignment[]   @relation("PackerAssignedBy")
  statusHistoryChanges OrderStatusHistory[]
  salesActivities      SalesDailyActivity[] @relation("SalesActivityAgent")
  salesOrders          SalesDirectOrder[]   @relation("SalesOrderAgent")
  incidentsAsEmployee  Incident[]           @relation("IncidentEmployee")
  incidentsReported    Incident[]           @relation("IncidentReportedBy")
  incidentsCreated     Incident[]           @relation("IncidentCreatedBy")
  brandingUpdates      CompanyBranding[]    @relation("BrandingUpdatedBy")

  @@unique([tenantId, username])
  @@map("users")
}

model Order {
  id             String      @id @default(uuid())
  tenantId       String      @map("tenant_id")
  trackingNumber String      @map("tracking_number")
  platform       Platform
  carrierName    String?     @map("carrier_name")
  shopName       String?     @map("shop_name")
  status         OrderStatus @default(INBOUND)
  priority       Int         @default(0)
  delayLevel     Int         @default(0) @map("delay_level")
  slaStartedAt   DateTime    @default(now()) @map("sla_started_at")
  slaCompletedAt DateTime?   @map("sla_completed_at")
  d4NotifiedAt   DateTime?   @map("d4_notified_at")
  workDate       DateTime    @default(now()) @map("work_date")
  archivedAt     DateTime?   @map("archived_at")
  scannedById    String      @map("scanned_by")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  tenant            Tenant               @relation(fields: [tenantId], references: [id])
  scannedBy         User                 @relation("ScannedBy", fields: [scannedById], references: [id])
  statusHistory     OrderStatusHistory[]
  pickerAssignments PickerAssignment[]
  packerAssignments PackerAssignment[]
  slaEscalations    SlaEscalation[]

  // @@unique([tenantId, trackingNumber]) — replaced by partial unique index (archived_at IS NULL) via raw SQL migration
  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, priority(sort: Desc), createdAt(sort: Asc)])
  @@index([tenantId, shopName])
  @@index([tenantId, workDate])
  @@index([tenantId, archivedAt])
  @@index([tenantId, status, archivedAt])
  @@map("orders")
}

model OrderStatusHistory {
  id          String       @id @default(uuid())
  orderId     String       @map("order_id")
  fromStatus  OrderStatus? @map("from_status")
  toStatus    OrderStatus  @map("to_status")
  changedById String       @map("changed_by")
  changedAt   DateTime     @default(now()) @map("changed_at")

  order     Order @relation(fields: [orderId], references: [id])
  changedBy User  @relation(fields: [changedById], references: [id])

  @@index([orderId, fromStatus, toStatus], map: "order_status_history_order_id_from_status_to_status_idx")
  @@map("order_status_history")
}

model PickerAssignment {
  id           String    @id @default(uuid())
  orderId      String    @map("order_id")
  pickerId     String    @map("picker_id")
  assignedById String    @map("assigned_by")
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  completedAt  DateTime? @map("completed_at")

  order      Order @relation(fields: [orderId], references: [id])
  picker     User  @relation("PickerUser", fields: [pickerId], references: [id])
  assignedBy User  @relation("PickerAssignedBy", fields: [assignedById], references: [id])

  @@index([pickerId, completedAt])
  @@map("picker_assignments")
}

model PackerAssignment {
  id           String    @id @default(uuid())
  orderId      String    @map("order_id")
  packerId     String    @map("packer_id")
  assignedById String    @map("assigned_by")
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  completedAt  DateTime? @map("completed_at")

  order      Order @relation(fields: [orderId], references: [id])
  packer     User  @relation("PackerUser", fields: [packerId], references: [id])
  assignedBy User  @relation("PackerAssignedBy", fields: [assignedById], references: [id])

  @@index([packerId, completedAt])
  @@map("packer_assignments")
}

model SlaEscalation {
  id            String   @id @default(uuid())
  orderId       String   @map("order_id")
  tenantId      String   @map("tenant_id")
  fromLevel     Int?     @map("from_level")
  toLevel       Int      @map("to_level")
  triggeredAt   DateTime @default(now()) @map("triggered_at")
  triggerSource String   @map("trigger_source")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([tenantId, triggeredAt(sort: Desc)])
  @@map("sla_escalations")
}

// ─── Sales Agent Module ──────────────────────────────────────────────────────
// Fully isolated from the warehouse Order pipeline above.

model SalesDailyActivity {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  agentId    String   @map("agent_id")
  reportDate DateTime @map("report_date") @db.Date
  storeName  String   @map("store_name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  agent              User                     @relation("SalesActivityAgent", fields: [agentId], references: [id])
  contentPosts       SalesContentPost[]
  liveSellingMetrics SalesLiveSellingMetric[]
  marketplaceReport  SalesMarketplaceReport?

  @@unique([agentId, reportDate, storeName])
  @@index([tenantId, reportDate])
  @@index([agentId, reportDate])
  @@map("sales_daily_activity")
}

model SalesContentPost {
  id         String          @id @default(uuid())
  activityId String          @map("activity_id")
  platform   SalesPlatform
  postType   ContentPostType @map("post_type")
  completed  Boolean         @default(false)
  note       String?

  activity SalesDailyActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, platform, postType])
  @@map("sales_content_post")
}

model SalesLiveSellingMetric {
  id         String        @id @default(uuid())
  activityId String        @map("activity_id")
  platform   SalesPlatform
  hours      Decimal       @default(0) @db.Decimal(6, 2)
  followers  Int           @default(0)
  likes      Int           @default(0)
  views      Int           @default(0)
  shares     Int           @default(0)
  comments   Int           @default(0)
  orders     Int           @default(0)

  activity SalesDailyActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, platform])
  @@map("sales_live_selling_metric")
}

model SalesMarketplaceReport {
  id              String @id @default(uuid())
  activityId      String @unique @map("activity_id")
  inquiries       Int    @default(0)
  listingsCreated Int    @default(0) @map("listings_created")

  activity SalesDailyActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("sales_marketplace_report")
}

model SalesDirectOrder {
  id           String      @id @default(uuid())
  tenantId     String      @map("tenant_id")
  agentId      String      @map("agent_id")
  orderDate    DateTime    @map("order_date") @db.Date
  storeName    String      @map("store_name")
  saleChannel  SaleChannel @map("sale_channel")
  companyName  String      @map("company_name")
  customerName String      @map("customer_name")
  deliveryCost Decimal     @default(0) @map("delivery_cost") @db.Decimal(12, 2)
  totalAmount  Decimal     @default(0) @map("total_amount") @db.Decimal(12, 2)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  agent User                   @relation("SalesOrderAgent", fields: [agentId], references: [id])
  items SalesDirectOrderItem[]

  @@index([tenantId, orderDate])
  @@index([agentId, orderDate])
  @@index([tenantId, companyName])
  @@index([tenantId, customerName])
  @@map("sales_direct_order")
}

model SalesDirectOrderItem {
  id            String  @id @default(uuid())
  directOrderId String  @map("direct_order_id")
  productName   String  @map("product_name")
  price         Decimal @default(0) @db.Decimal(12, 2)
  quantity      Int     @default(1)

  directOrder SalesDirectOrder @relation(fields: [directOrderId], references: [id], onDelete: Cascade)

  @@index([productName])
  @@map("sales_direct_order_item")
}

// ─── Inventory Module ────────────────────────────────────────────────────────
// QR-based warehouse inventory tracking with product master / warehouses /
// reserved-stock thresholds. Independent of the Order pipeline.

model ProductCategory {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("product_categories")
}

model Product {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  categoryId        String    @map("category_id")
  productCode       String    @map("product_code")
  name              String
  defaultUnit       StockUnit @default(KG) @map("default_unit")
  reservedThreshold Float     @default(0) @map("reserved_threshold")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  category   ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  stockItems StockItem[]

  @@unique([tenantId, productCode])
  @@index([tenantId, categoryId])
  @@map("products")
}

model Warehouse {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  address   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stockItems    StockItem[]
  movementsFrom StockMovement[] @relation("MovementFrom")
  movementsTo   StockMovement[] @relation("MovementTo")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("warehouses")
}

model StockItem {
  id          String      @id @default(uuid())
  tenantId    String      @map("tenant_id")
  productId   String      @map("product_id")
  warehouseId String      @map("warehouse_id")
  unit        StockUnit
  quantity    Float
  batchNumber String      @map("batch_number")
  status      StockStatus @default(IN_STOCK)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  product   Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  movements StockMovement[]

  @@index([tenantId, status])
  @@index([tenantId, productId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, batchNumber])
  @@map("stock_items")
}

model StockMovement {
  id              String       @id @default(uuid())
  stockItemId     String       @map("stock_item_id")
  type            MovementType
  fromWarehouseId String?      @map("from_warehouse_id")
  toWarehouseId   String?      @map("to_warehouse_id")
  scannedById     String       @map("scanned_by")
  scannedAt       DateTime     @default(now()) @map("scanned_at")

  stockItem     StockItem  @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse? @relation("MovementFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse? @relation("MovementTo", fields: [toWarehouseId], references: [id])

  @@index([stockItemId])
  @@index([scannedAt])
  @@map("stock_movements")
}

// ─── Incident Report Module ──────────────────────────────────────────────────
// Formal HR/operations incident documentation. Independent of order pipeline.

model Incident {
  id                 String       @id @default(uuid())
  tenantId           String       @map("tenant_id")
  incidentType       IncidentType @map("incident_type")
  incidentDate       DateTime     @map("incident_date")
  employeeUserId     String       @map("employee_user_id")
  employeeFullName   String       @map("employee_full_name")
  employeeEmail      String       @map("employee_email")
  recipientEmail     String       @map("recipient_email")
  reportedByUserId   String       @map("reported_by_user_id")
  reportedByFullName String       @map("reported_by_full_name")
  reportedByRole     String       @map("reported_by_role")
  adminDescription   String       @map("admin_description") @db.Text
  trackingNumber     String?      @map("tracking_number")
  platform           Platform?
  shopName           String?      @map("shop_name")
  witnessName        String?      @map("witness_name")
  witnessPosition    String?      @map("witness_position")
  signedFilePath     String?      @map("signed_file_path")
  signedFileMime     String?      @map("signed_file_mime")
  signedUploadedAt   DateTime?    @map("signed_uploaded_at")
  emailSentAt        DateTime?    @map("email_sent_at")
  emailSentTo        String?      @map("email_sent_to")
  createdById        String       @map("created_by")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  employee   User @relation("IncidentEmployee", fields: [employeeUserId], references: [id], onDelete: Restrict)
  reportedBy User @relation("IncidentReportedBy", fields: [reportedByUserId], references: [id], onDelete: Restrict)
  createdBy  User @relation("IncidentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, incidentDate(sort: Desc)])
  @@index([tenantId, employeeUserId])
  @@index([tenantId, incidentType])
  @@map("incidents")
}

model CompanyBranding {
  id          String   @id @default(uuid())
  tenantId    String   @unique @map("tenant_id")
  companyName   String   @map("company_name")
  address       String?  @map("address")
  email         String?  @map("email")
  contactNumber String?  @map("contact_number")
  logoPath      String?  @map("logo_path")
  logoMime      String?  @map("logo_mime")
  updatedById String   @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  updatedBy User @relation("BrandingUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@map("company_branding")
}
