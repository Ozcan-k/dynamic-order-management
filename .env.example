# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL 16) ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=dom_user
DB_PASSWORD=changeme
DB_NAME=dom_db

# Prisma needs the full connection URL
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=8h

# ── Email (Nodemailer — nightly report + D4 supervisor alerts) ────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
MAIL_FROM="DOM System <your@email.com>"
SUPERVISOR_EMAIL=supervisor@example.com

# ── BullMQ Jobs ───────────────────────────────────────────────────────────────
# SLA_SWEEP_CRON: how often to escalate D-levels (default every 15 min)
SLA_SWEEP_CRON=*/15 * * * *
# NIGHTLY_REPORT_CRON: daily email report time
NIGHTLY_REPORT_CRON=0 21 * * *
